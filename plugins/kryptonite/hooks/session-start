#!/usr/bin/env bash
# SessionStart hook for kryptonite plugin
# Injects the using-kryptonite SKILL.md into session context as EXTREMELY_IMPORTANT
# so kryptonite skills auto-discover at session start.

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read using-kryptonite content
using_kryptonite_content=$(cat "${PLUGIN_ROOT}/skills/using-kryptonite/SKILL.md" 2>&1 || echo "Error reading using-kryptonite skill")

# Escape string for JSON embedding using bash parameter substitution.
# Each ${s//old/new} is a single C-level pass - orders of magnitude
# faster than the character-by-character loop this replaces.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

using_kryptonite_escaped=$(escape_for_json "$using_kryptonite_content")
session_context="<EXTREMELY_IMPORTANT>\nYou have kryptonite — skills for Claude Code agent teams.\n\n**Below is the full content of your 'kryptonite:using-kryptonite' skill — your introduction to using kryptonite skills. For all other skills, use the 'Skill' tool:**\n\n${using_kryptonite_escaped}\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON.
# Claude Code hooks expect hookSpecificOutput.additionalContext (nested).
# Kryptonite is Claude-Code-only, so we only emit that shape; if CLAUDE_PLUGIN_ROOT
# isn't set, exit silently (plugin still works, just no context injection).
#
# Uses printf instead of heredoc to work around bash 5.3+ heredoc hang.
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
fi

exit 0
